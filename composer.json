{
    "name": "piko/migrate",
    "description": "A lightweight database migration tool.",
    "keywords": [
        "migration",
        "piko",
        "database"
    ],
    "license": "MIT",
    "require": {
        "ulrichsg/getopt-php": "^4.0",
        "dakujem/migrun": "^1.0",
        "league/container": "^5.2"
    },
    "require-dev": {
      "squizlabs/php_codesniffer" : "^3.7",
		  "phpstan/phpstan" : "^2.2",
        "phpunit/phpunit": "^12.5"
    },
    "bin": ["bin/migrate"],
    "scripts": {
      "test": "phpunit",
      "lint": [
        "@phpcs",
        "@phpstan"
      ],
      "phpcs" : "phpcs --standard=PSR12 --extensions=php --ignore='*/messages/*' src",
      "phpstan" : "phpstan"
    },
    "autoload": {
        "psr-4": {
            "Piko\\Migrate\\": "src"
        }
    }
}
